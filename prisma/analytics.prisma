// ------------------------------------------------------------
// Afterlife Service — Prisma Schema (MongoDB)
// Analytics schema content can live here alongside other models.
// ------------------------------------------------------------

model AuditLog {
    id          String   @id @default(auto()) @map("_id") @db.ObjectId
    subjectType String // "Memorial" | "Post" | "Event" | ...
    subjectId   String
    actorUserId String?
    action      String
    payload     Json?
    createdAt   DateTime @default(now())

    @@index([subjectType, subjectId, createdAt])
}

