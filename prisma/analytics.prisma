// track interactions (likes, comments, shares, etc.)
model Interaction {
    id         String   @id @default(auto()) @map("_id") @db.ObjectId
    type       String // "LIKE" | "COMMENT" | "SHARE" | ...
    targetType String // "Post" | "Event" | "Memorial" | ...
    targetId   String
    userId     String   @db.ObjectId
    sessionId  String?
    payload    Json? // e.g. { commentId: "...", shareMessage: "..." }
    createdAt  DateTime @default(now())

    @@index([type, targetType, targetId, createdAt])
    @@index([userId, createdAt])
    @@index([sessionId, createdAt])
}
